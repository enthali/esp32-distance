{"created": "2026-03-17T07:57:55.821670", "current_version": "1.0.0", "project": "ESP32 Distance Sensor", "versions": {"1.0.0": {"created": "2026-03-17T07:57:55.821667", "creator": {"program": "sphinx_needs", "version": "7.0.0"}, "needs": {"US_DEV_1": {"acceptance_criteria": "", "api_signature": "", "arch": {}, "avatar": null, "closed_at": null, "completion": null, "component": "", "constraints": [], "constraints_error": null, "constraints_passed": true, "constraints_results": {}, "content": "**Role:** Developer\n\n**Story:**\nAs a developer, I want a modular component structure so that I can add a\nnew sensor or display type without modifying the core application logic.\n\n**Value:**\nThe component-based architecture allows extending the firmware by adding\nor replacing components. Existing components serve as reference\nimplementations. The developer is not required to understand the full\nsystem to add a new peripheral.", "created_at": null, "docname": "10_userstories/us_developer", "doctype": ".rst", "duration": null, "external_css": "external_link", "external_url": null, "has_dead_links": false, "has_forbidden_dead_links": false, "header_file": "", "id": "US_DEV_1", "id_prefix": null, "is_external": false, "is_import": false, "is_modified": false, "jinja_content": false, "layout": null, "lineno": 7, "links": ["REQ_SYS_ARCH_1"], "links_back": ["SPEC_DEV_OV_INDEX_WHO"], "max_amount": null, "max_content_lines": null, "modifications": 0, "parameters": "", "params": null, "parent_need": null, "parent_needs": [], "parent_needs_back": [], "parts": {}, "post_content": null, "post_template": null, "pre_content": null, "pre_template": null, "prefix": null, "priority": "", "query": null, "rationale": "", "returns": "", "section_name": "Developer User Stories", "sections": ["Developer User Stories"], "service": null, "signature": null, "specific": null, "status": "approved", "style": null, "tags": ["developer", "firmware", "extensibility"], "template": null, "title": "Modular Firmware Extensibility", "type": "story", "type_name": "User Story", "updated_at": null, "url": null, "url_postfix": null, "user": null}}, "needs_amount": 1}}}