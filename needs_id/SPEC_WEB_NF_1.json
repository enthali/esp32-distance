{"created": "2026-03-16T20:52:43.228821", "current_version": "1.0.0", "project": "ESP32 Distance Sensor", "versions": {"1.0.0": {"created": "2026-03-16T20:52:43.228818", "creator": {"program": "sphinx_needs", "version": "7.0.0"}, "needs": {"SPEC_WEB_NF_1": {"acceptance_criteria": "", "api_signature": "", "arch": {}, "avatar": null, "closed_at": null, "completion": null, "component": "", "constraints": [], "constraints_error": null, "constraints_passed": true, "constraints_results": {}, "content": "**Design:** All web pages use responsive CSS with mobile-first layout.\n\n**Implementation:**\n\n- viewport meta tag set for mobile scaling\n- Minimum usable width: 320px\n- Touch targets: minimum 44\u00d744px for all interactive elements\n- Font sizes: minimum 16px base to avoid zoom on mobile\n- Page load target: < 3 seconds on typical mobile connection\n- Navigation between pages < 500ms (single-page updates, no full reload)\n\n**Validation:** Test on 320px viewport, verify all touch targets are reachable,\nconfirm no horizontal scroll at minimum width.", "created_at": null, "docname": "12_design/spec_web_server", "doctype": ".rst", "duration": null, "external_css": "external_link", "external_url": null, "has_dead_links": false, "has_forbidden_dead_links": false, "header_file": "", "id": "SPEC_WEB_NF_1", "id_prefix": null, "is_external": false, "is_import": false, "is_modified": false, "jinja_content": false, "layout": null, "lineno": 1220, "links": ["REQ_WEB_NF_1", "REQ_WEB_NF_2"], "links_back": [], "max_amount": null, "max_content_lines": null, "modifications": 0, "parameters": "", "params": null, "parent_need": null, "parent_needs": [], "parent_needs_back": [], "parts": {}, "post_content": null, "post_template": null, "pre_content": null, "pre_template": null, "prefix": null, "priority": "", "query": null, "rationale": "", "returns": "", "section_name": "Non-Functional Design", "sections": ["Non-Functional Design", "Web Server Design Specification"], "service": null,