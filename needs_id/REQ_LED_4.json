{"created": "2026-03-09T20:25:22.687335", "current_version": "", "project": "ESP32 Distance Sensor", "versions": {"": {"created": "2026-03-09T20:25:22.687333", "creator": {"program": "sphinx_needs", "version": "7.0.0"}, "needs": {"REQ_LED_4": {"acceptance_criteria": "", "api_signature": "", "arch": {}, "avatar": null, "closed_at": null, "completion": null, "component": "", "constraints": [], "constraints_error": null, "constraints_passed": true, "constraints_results": {}, "content": "**Description:** The system SHALL display specified RGB colors accurately on WS2812 LEDs for\nreliable visual feedback to users.\n\n**Rationale:** Color accuracy is essential for distance visualization effectiveness; users\nmust be able to distinguish between different states (normal/error conditions).\n\n**Acceptance Criteria:**\n\n- AC-1: Primary colors (red, green, blue) SHALL display distinctly and accurately\n- AC-2: White color SHALL appear as true white without color bias\n- AC-3: Black/off state SHALL turn LEDs completely off\n- AC-4: Color transitions SHALL be immediate when hardware is updated\n\n**Verification:** Display primary colors and verify visual accuracy, test white balance and\noff state, measure color transition timing.", "created_at": null, "docname": "11_requirements/req_led_controller", "doctype": ".rst", "duration": null, "external_css": "external_link", "external_url": null, "has_dead_links": false, "has_forbidden_dead_links": false, "header_file": "", "id": "REQ_LED_4", "id_prefix": null, "is_external": false, "is_import": false, "is_modified": false, "jinja_content": false, "layout": null, "lineno": 91, "links": ["REQ_LED_2"], "links_back": ["US_DISPLAY", "SPEC_LED_API_2", "SPEC_LED_DATA_1", "API_COMP_LED_CONTROLLER", "API_STRUCT_LED_COLOR", "API_FUNC_LED_SET_PIXEL", "API_FUNC_LED_GET_PIXEL", "API_FUNC_LED_SHOW", "API_FUNC_LED_COLOR_RGB", "API_FUNC_LED_COLOR_BRIGHTNESS"], "max_amount": null, "max_content_lines": null, "modifications": 0, "parameters": "", "params": null, "parent_need": null, "parent_needs": [], "parent_needs_back": [], "parts": {}, "post_content": null, "post_template": null, "pre_content": null, "pre_template": null, "prefix": null, "priority": "mandatory", "query": null, "rationale": "", "returns": "", "section_name": "Functional Requirements", "sections": ["Functional Requirements", "LED Controller Requirements"], "service": null, "signature": null, "specific": null, "status": "approved", "style": null, "tags": ["led", "quality", "color-accuracy"], "template": null, "title": "Accurate Color Display", "type": "req", "type_name": "Requirement", "updated_at": null, "url": null, "url_postfix": null, "user": null}}, "needs_amount": 1}}}