{"created": "2026-03-16T20:56:42.010938", "current_version": "1.0.0", "project": "ESP32 Distance Sensor", "versions": {"1.0.0": {"created": "2026-03-16T20:56:42.010935", "creator": {"program": "sphinx_needs", "version": "7.0.0"}, "needs": {"US_DEV_2": {"acceptance_criteria": "", "api_signature": "", "arch": {}, "avatar": null, "closed_at": null, "completion": null, "component": "", "constraints": [], "constraints_error": null, "constraints_passed": true, "constraints_results": {}, "content": "**Role:** Developer\n\n**Story:**\nAs a developer, I want README, overview pages and guides to be linked to\nthe specs they describe, so that when a spec changes, supporting docs are\nautomatically in the change impact scope \u2014 including which development\nenvironments are supported and what known limitations exist.\n\n**Value:**\nWithout traceability, supporting documentation silently goes stale when\nspecs change. A developer setting up for the first time needs to know\nwhich environments are supported (devcontainer / Codespaces \u2014 not\nWindows) and where to find known limitations, without discovering them\nby trial and error.", "created_at": null, "docname": "10_userstories/us_developer", "doctype": ".rst", "duration": null, "external_css": "external_link", "external_url": null, "has_dead_links": false, "has_forbidden_dead_links": false, "header_file": "", "id": "US_DEV_2", "id_prefix": null, "is_external": false, "is_import": false, "is_modified": false, "jinja_content": false, "layout": null, "lineno": 26, "links": [], "links_back": ["REQ_DEV_DOC_1", "REQ_DEV_README_1", "REQ_DEV_OV_INDEX_1", "REQ_DEV_OV_HW_1", "REQ_DEV_OV_QS_1", "REQ_DEV_GUIDE_QEMU_1", "REQ_DEV_GUIDE_MODES_1", "REQ_DEV_GUIDE_DEBUG_1", "REQ_DEV_GUIDE_FLASH_1", "REQ_DEV_ENV_1", "REQ_DEV_LIMITS_1", "SPEC_DEV_OV_INDEX_WHO"], "max_amount": null, "max_content_lines": null, "modifications": 0, "parameters": "", "params": null, "parent_need": null, "parent_needs": [], "parent_needs_back": [], "parts": {}, "post_content": null, "post_template": null, "pre_content": null, "pre_template": null, "prefix": null, "priority": "", "query": null, "rationale": "", "returns": "", "section_name": "Developer User Stories", "sections": ["Developer User Stories"], "service": null, "signature": null, "specific": null, "status": "approved", "style": null, "tags": ["developer", "documentation", "traceability"], "template": null, "title": "Traceable Supporting Documentation", "type": "story", "type_name": "User Story", "updated_at": null, "url": null, "url_postfix": null, "user": null}}, "needs_amount": 1}}}